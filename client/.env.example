# Config de la Web App Firebase (Console Firebase > Paramètres du projet > Vos applications > SDK setup and configuration)
# Copier ce fichier vers .env (à la racine de client/) et remplir avec les vraies valeurs.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
